# Copy to .env for local `netlify dev` — never commit .env
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@nexpertsai.com
BREVO_SENDER_NAME=Nexperts Academy
# Lead inbox (student reply-to + internal notification). Same as teamInbox in js/enquiry-config.js.
# Aliases also read: BREVO_ENQUIRY_TO, NEXPERTS_ENQUIRY_EMAIL, ENQUIRY_EMAIL. Comma-separated = multiple recipients.
BREVO_INTERNAL_TO=contact@iqmath.in
# Optional; if set, must match secret in js/enquiry-config.js
BREVO_ENQUIRY_SECRET=

# Optional — links inside HTML emails (defaults shown)
# NEXPERTS_PUBLIC_SITE_URL=https://www.nexpertsacademy.com
# NEXPERTS_LEADS_SHEET_URL=https://docs.google.com/spreadsheets/d/.../edit
